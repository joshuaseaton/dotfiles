# See https://ghostty.org/docs/config/reference

#
# Font
#

font-family = "Cascadia Code"
font-size = 15
font-style = Light

#
# Window
#

background-blur = 3
background-opacity = 0.8
confirm-close-surface = false
maximize = true
mouse-hide-while-typing = true
quit-after-last-window-closed=true
window-padding-x = 16

#
# Colors
#

# Near-black
background = 181818
# Light grey
foreground = e0e0e0
# By default ghostty maps ansi white to a grey; set it to off-white
palette = 7=#eeeeee
# Medium blue
selection-background = 4466aa
# White
selection-foreground = ffffff

#
# Cursor
#

copy-on-select = clipboard
cursor-style-blink = false

#
# Scrolling
#

scrollback-limit = 100000

#
# Shell
#

command = .cargo/bin/nu --login --commands zellij_start

#
# Keybindings
#

macos-option-as-alt = true

# Cmd + Left on macOS: home (Ctrl+A).
keybind = cmd+left=text:\x01

# Cmd + Right on macOS: end (Ctrl+E).
keybind = cmd+right=text:\x05

# Cmd + S on macOS: reinterpreted as Ctrl + S.
keybind = cmd+s=text:\x13

# Shift + Enter: newline without execution.
keybind = shift+enter=text:\n

# Ctrl + N: open new Ghostty instance.
keybind = ctrl+n=new_window
