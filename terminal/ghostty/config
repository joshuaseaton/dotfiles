# See https://ghostty.org/docs/config/reference

#
# Font
#

font-family = "Cascadia Code"
font-size = 15
font-style = Light

#
# Window
#

app-notifications = no-clipboard-copy
background-blur = 3
background-opacity = 0.8
clipboard-read = allow
confirm-close-surface = false
macos-titlebar-style = hidden
maximize = true
mouse-hide-while-typing = true
quit-after-last-window-closed=true

#
# Colors
#

# Near-black
background = 181818
# Light grey
foreground = e0e0e0
# By default ghostty maps ansi white to a grey; set it to off-white
palette = 7=#eeeeee
# Medium blue
selection-background = 4466aa
# White
selection-foreground = ffffff

#
# Cursor
#

copy-on-select = clipboard
cursor-style-blink = false

#
# Scrolling
#

scrollback-limit = 100000

#
# Shell
#

command = .cargo/bin/nu --login --commands zellij-start

#
# Keybindings
#

macos-option-as-alt = true

# Remap each use of Cmd here with Ctrl:
keybind = cmd+c=text:\x03
keybind = cmd+p=text:\x1b[112;5u
keybind = cmd+s=text:\x13
keybind = cmd+y=text:\x19
keybind = cmd+z=text:\x1a
keybind = cmd+shift+p=text:\x1b[112;6u

# Cmd + Left on macOS: Home.
keybind = cmd+left=text:\x1b[H

# Cmd + Right on macOS: End.
keybind = cmd+right=text:\x1b[F

# Cmd + Shift + Left on macOS: Shift+Home (select to start of line).
keybind = cmd+shift+left=text:\x1b[1;2H

# Cmd + Shift + Right on macOS: Shift+End (select to end of line).
keybind = cmd+shift+right=text:\x1b[1;2F

# Ctrl + N: open new Ghostty instance.
keybind = ctrl+n=new_window

# Ctrl + V: paste from system clipboard (bracketed paste), bypassing OSC 52
# reads which Zellij doesn't forward.
keybind = ctrl+v=paste_from_clipboard

# Ctrl + Shift + P: unbind so that this can be used in Flow.
keybind = ctrl+shift+p=unbind

# Shift + Enter: newline without execution.
keybind = shift+enter=text:\n

# ghostty consumes these keypresses for its own actions, so we need to redefine
# how we want them to be passed through to terminal programs with "performable",
# which forwards the keys if a native ghostty selection is not active.
keybind = performable:shift+home=adjust_selection:home
keybind = performable:shift+end=adjust_selection:end
keybind = performable:alt+left=goto_split:left
keybind = performable:alt+right=goto_split:right
