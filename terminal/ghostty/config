# See https://ghostty.org/docs/config/reference

#
# Font
#

font-family = "Cascadia Code"
font-size = 15
font-style = Light

#
# Window
#

app-notifications = no-clipboard-copy
background-blur = 3
background-opacity = 0.8
confirm-close-surface = false
maximize = true
mouse-hide-while-typing = true
quit-after-last-window-closed=true
window-padding-x = 16

#
# Colors
#

# Near-black
background = 181818
# Light grey
foreground = e0e0e0
# By default ghostty maps ansi white to a grey; set it to off-white
palette = 7=#eeeeee
# Medium blue
selection-background = 4466aa
# White
selection-foreground = ffffff

#
# Cursor
#

copy-on-select = clipboard
cursor-style-blink = false

#
# Scrolling
#

scrollback-limit = 100000

#
# Shell
#

command = .cargo/bin/nu --login --commands zellij_start

#
# Keybindings
#

macos-option-as-alt = true

# Cmd + Left on macOS: Home.
keybind = cmd+left=text:\x1b[H

# Cmd + Shift + Left on macOS: Shift+Home (select to start of line).
keybind = cmd+shift+left=text:\x1b[1;2H

# Cmd + Right on macOS: End.
keybind = cmd+right=text:\x1b[F

# Cmd + Shift + Right on macOS: Shift+End (select to end of line).
keybind = cmd+shift+right=text:\x1b[1;2F

# Cmd + Z on macOS: Ctrl+Z (undo in micro, suspend in shell).
keybind = cmd+z=text:\x1a

# Cmd + Y on macOS: Ctrl+Y (redo in micro).
keybind = cmd+y=text:\x19

# Cmd + S on macOS: Ctrl+S (save in micro).
keybind = cmd+s=text:\x13

# Shift + Enter: newline without execution.
keybind = shift+enter=text:\n

# Ctrl + N: open new Ghostty instance.
keybind = ctrl+n=new_window

# By default ghostty binds shift+home/end to adjust_selection, consuming the
# keys before they reach the terminal app (e.g., micro). The performable: prefix
# forwards the keys unless a native ghostty selection is active.
keybind = performable:shift+home=adjust_selection:home
keybind = performable:shift+end=adjust_selection:end
